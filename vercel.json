{
  "version": 3,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    },
    {
      "src": "api/[[...path]].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[[...path]].ts" },
    { "src": "/(.*)", "dest": "/api/[[...path]].ts" }
  ]
}
